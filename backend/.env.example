# Application
APP_NAME=Atlas AI
DEBUG=false
SECRET_KEY=your-super-secret-key-change-this-in-production

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB_NAME=atlas_ai

# Redis
REDIS_URL=redis://localhost:6379
RATE_LIMIT_PER_MINUTE=100

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_DEFAULT_MODEL=gpt-4o

# Groq
GROQ_API_KEY=gsk_your-groq-api-key
GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIR=./chroma_data

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=50

# CORS (JSON list of allowed origins)
CORS_ORIGINS=["http://localhost:5173","https://atlas-swart-kappa-13.vercel.app"]
FRONTEND_URL=https://atlas-swart-kappa-13.vercel.app

# Email (optional - for password reset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@atlas-ai.com

# RAG Pipeline
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256
